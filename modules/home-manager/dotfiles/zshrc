# ---------------------------------------------------------------------------
# `danix` launcher
#
# `danix`           → fzf menu of helpers.
# `danix <sub>`     → runs `danix-<sub>` directly (composes with history).
#
# Single source of truth: add a new helper by adding one line here.
# ---------------------------------------------------------------------------
typeset -gA _DANIX_COMMANDS=(
  add     "Agentically make a change to this flake"
  ask     "Ask Pi questions about this nix setup (read-only)"
  pi      "Agentically add/tweak a Pi addon (skill, prompt template, or settings)"
  switch  "Rebuild & activate the system (sudo)"
  up      "nix flake update + switch"
  update  "Agentically update manually-wrapped packages"
  vim     "Agentically make a change to the neovim (davim) config"
)

danix() {
  if (( $# > 0 )); then
    local sub="$1"; shift
    if [[ -z "${_DANIX_COMMANDS[$sub]+x}" ]]; then
      echo "danix: unknown subcommand '$sub'" >&2
      echo "available: ${(ko)_DANIX_COMMANDS}" >&2
      return 2
    fi
    "danix-$sub" "$@"
    return
  fi

  local choice
  choice=$(
    for k in ${(ko)_DANIX_COMMANDS}; do
      printf '%s\t%s\n' "$k" "${_DANIX_COMMANDS[$k]}"
    done | fzf --with-nth=1,2 --delimiter=$'\t' \
               --prompt='danix> ' --height=40% --reverse \
               --header='Pick a danix-* helper'
  ) || return 130
  local sub="${choice%%$'\t'*}"
  [[ -n $sub ]] && "danix-$sub"
}


# Yazi shell wrapper -- cd to yazi's cwd on exit
function yy() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

# Auto-attach to Zellij (skip in VS Code, cmux, or if already inside a multiplexer)
if [[ -z "$TMUX" && -z "$ZELLIJ" && -z "$VSCODE_PID" && -z "$CMUX_WORKSPACE_ID" ]]; then
  zellij attach default || zellij -s default
fi

# Source local settings if present (personal aliases, env vars, etc.).
# This file is intentionally not Nix-managed: it's a scratch space for
# quick per-machine tweaks that don't warrant a rebuild. Anything
# structured / long-lived should go in ~/.config/dave_nix/private.nix.
if [ -e "${HOME}/local_shell_settings.sh" ]; then
  source "${HOME}/local_shell_settings.sh"
fi

# ---------------------------------------------------------------------------
# danix-* helpers
#
# `danix-switch`, `danix-up`, `danix-update`, and `danix-add` are the
# user-facing nix-management commands. The `danix` launcher (defined
# at the bottom of this block) gives them a shared menu front-end.
#
# All of these are functions (rather than `shellAliases` entries) so
# the launcher can dispatch by name without `eval`. Old names
# (`nixswitch`, `nixup`, `nixupdate-wrapped`) survive as deprecation
# shims in shellAliases for one transition cycle.
# ---------------------------------------------------------------------------

# Rebuild & activate the system. Bootstraps `private.nix` from the
# template on first run if it's missing.
danix-switch() {
  local repo_path
  repo_path="$(cat ~/.config/dave_nix/repo-path 2>/dev/null)"
  if [ ! -f "$HOME/.config/dave_nix/private.nix" ]; then
    if [ -z "$repo_path" ]; then
      echo "danix-switch: cannot bootstrap — ~/.config/dave_nix/repo-path is missing." >&2
      echo "Set DAVE_NIX_REPO and copy private.nix.example manually, then retry." >&2
      return 1
    fi
    mkdir -p "$HOME/.config/dave_nix"
    cp "$repo_path/private.nix.example" "$HOME/.config/dave_nix/private.nix"
    echo "Created $HOME/.config/dave_nix/private.nix from template."
    echo "Edit it with your details, then re-run danix-switch."
    return 0
  fi
  if [ -z "$repo_path" ]; then
    echo "danix-switch: ~/.config/dave_nix/repo-path is missing." >&2
    return 1
  fi
  if sudo darwin-rebuild switch --flake "${repo_path}#default" --impure; then
    echo
    echo "✓ danix-switch completed at $(date '+%a %d %b %Y %H:%M:%S')"
  else
    return $?
  fi
}

# nix flake update + danix-switch.
danix-up() {
  local repo_path
  repo_path="$(cat ~/.config/dave_nix/repo-path 2>/dev/null)"
  if [ -z "$repo_path" ]; then
    echo "danix-up: ~/.config/dave_nix/repo-path is missing — run danix-switch once first." >&2
    return 1
  fi
  pushd "$repo_path" >/dev/null || return 1
  nix flake update
  popd >/dev/null
  danix-switch
}

# Agentic update of manually-wrapped (non-flake) packages. Edits files
# only — does NOT rebuild. If invoked inside zellij, opens a floating
# pane; otherwise runs inline.
danix-update() {
  if [ -n "$ZELLIJ" ]; then
    zellij run --floating --name nix-update -- zsh -ic _nixupdate_wrapped_run
  else
    _nixupdate_wrapped_run
  fi
}

# Worker for `danix-update` (kept under its old name to keep the diff small).
# Kept as a function so it's available in non-interactive subshells too
# (e.g. when zellij spawns a pane via `zsh -ic ...`).
#
# We invoke `op run` explicitly here rather than relying on the `pi` alias,
# because zsh expands aliases lazily inside functions and that expansion is
# unreliable across interactive/non-interactive subshell boundaries. The
# `op-account` file is written by home-manager from `private.opAccount`.
_nixupdate_wrapped_run() {
  local op_account repo_path
  op_account="$(cat ~/.config/dave_nix/op-account 2>/dev/null)"
  repo_path="$(cat ~/.config/dave_nix/repo-path 2>/dev/null)"
  cd "$repo_path" && op run --account="$op_account" --env-file ~/.secrets.template --no-masking -- \
    pi --thinking medium "$(cat ~/.config/dave_nix/nix-update-wrapped-prompt.md)"
}

# ---------------------------------------------------------------------------
# danix-add / danix-ask / danix-vim / danix-pi
#
# Each helper does its pre-flight checks (repo-path present, working tree
# clean where applicable) and prompts the user for a request *in the
# current shell*, then exec's `op run -- pi ...` directly — either inline
# or, when inside zellij, in a fresh floating pane.
#
# We deliberately do NOT wrap the launch in `zsh -ic "_danix_<name>_run"`
# inside the floating pane. An interactive zsh in the new pane races Pi's
# Kitty-keyboard-protocol negotiation (Pi sends `\e[?u` and waits ~150ms
# for a reply); when zsh has already done its terminal setup and a
# `read`-prompt has consumed bytes, that reply gets eaten and Pi falls
# back to a mode where Shift+Enter is indistinguishable from Enter — i.e.
# Shift+Enter submits the prompt instead of inserting a newline. Running
# `op run -- pi` as the floating pane's command directly avoids the race
# (TASK-0150).
# ---------------------------------------------------------------------------

# Internal: actually launch Pi. Args:
#   $1 = pane name (e.g. danix-add) — only used when ZELLIJ is set
#   $2 = repo path  (cwd for the Pi session)
#   $3 = op account (for `op run --account=`)
#   $4 = absolute path to the system-prompt MD file
#   $5 = optional initial user message; empty string means "drop into TUI"
_danix_launch_pi() {
  local name="$1" repo_path="$2" op_account="$3" prompt="$4" request="$5"
  if [ -n "$ZELLIJ" ]; then
    zellij run --floating --name "$name" --cwd "$repo_path" -- \
      op run --account="$op_account" --env-file ~/.secrets.template --no-masking -- \
      pi --thinking medium \
         --append-system-prompt "$prompt" \
         ${request:+"$request"}
  else
    op run --account="$op_account" --env-file ~/.secrets.template --no-masking -- \
      pi --thinking medium \
         --append-system-prompt "$prompt" \
         ${request:+"$request"}
  fi
}

# Internal: refuse if the repo working tree is dirty. Keeps the agent's
# commit focused on its own diff. Caller passes its name + repo path.
_danix_require_clean_tree() {
  local name="$1" repo_path="$2"
  if [ -n "$(git -C "$repo_path" status --porcelain)" ]; then
    echo "$name: working tree at $repo_path is dirty." >&2
    echo "Commit, stash, or discard pending changes first so the agent's commit stays focused." >&2
    git -C "$repo_path" -c color.status=always status --short >&2
    return 1
  fi
}

# danix-add — agentically make a change to this flake. Refuses to start
# on a dirty tree.
#
# Usage:
#   danix-add                          # prompts for a request, then runs Pi
#   danix-add "install ripgrep-all"    # uses arg as Pi's first message
danix-add() {
  local op_account repo_path request
  op_account="$(cat ~/.config/dave_nix/op-account 2>/dev/null)"
  repo_path="$(cat ~/.config/dave_nix/repo-path 2>/dev/null)"
  if [ -z "$repo_path" ]; then
    echo "danix-add: ~/.config/dave_nix/repo-path is missing — run danix-switch once first." >&2
    return 1
  fi
  _danix_require_clean_tree danix-add "$repo_path" || return 1
  if [ $# -gt 0 ]; then
    request="$1"
  else
    # No request supplied on the command line — prompt for one. Empty
    # input falls through to launching Pi with no initial message (the
    # system prompt tells it to ask the user in that case).
    print -P "%F{cyan}danix-add%f — what change would you like to make to dave_nix?"
    print -P "%F{cyan}        %f (e.g. \"install ripgrep-all\", \"add git alias lol\"; empty = drop into Pi TUI)"
    printf "> "
    IFS= read -r request || request=""
  fi
  _danix_launch_pi danix-add "$repo_path" "$op_account" \
    ~/.config/dave_nix/danix-add-prompt.md "$request"
}

# danix-ask — read-only Pi session that answers questions about this
# flake (what's installed, what keybindings exist, etc.). No clean-tree
# check; the agent doesn't edit anything.
danix-ask() {
  local op_account repo_path question
  op_account="$(cat ~/.config/dave_nix/op-account 2>/dev/null)"
  repo_path="$(cat ~/.config/dave_nix/repo-path 2>/dev/null)"
  if [ -z "$repo_path" ]; then
    echo "danix-ask: ~/.config/dave_nix/repo-path is missing — run danix-switch once first." >&2
    return 1
  fi
  if [ $# -gt 0 ]; then
    question="$1"
  else
    print -P "%F{cyan}danix-ask%f — what would you like to know about your nix setup?"
    print -P "%F{cyan}        %f (e.g. \"what's my telescope keybinding?\", \"is ripgrep installed?\"; empty = drop into Pi TUI)"
    printf "> "
    IFS= read -r question || question=""
  fi
  _danix_launch_pi danix-ask "$repo_path" "$op_account" \
    ~/.config/dave_nix/danix-ask-prompt.md "$question"
}

# danix-vim — agentically make a focused change to the neovim (davim)
# config under ./davim/. Same shape as danix-add but scoped to davim.
danix-vim() {
  local op_account repo_path request
  op_account="$(cat ~/.config/dave_nix/op-account 2>/dev/null)"
  repo_path="$(cat ~/.config/dave_nix/repo-path 2>/dev/null)"
  if [ -z "$repo_path" ]; then
    echo "danix-vim: ~/.config/dave_nix/repo-path is missing — run danix-switch once first." >&2
    return 1
  fi
  _danix_require_clean_tree danix-vim "$repo_path" || return 1
  if [ $# -gt 0 ]; then
    request="$1"
  else
    print -P "%F{cyan}danix-vim%f — what change would you like to make to your neovim config?"
    print -P "%F{cyan}        %f (e.g. \"add the oil.nvim plugin\", \"bind ,gs to lazygit\"; empty = drop into Pi TUI)"
    printf "> "
    IFS= read -r request || request=""
  fi
  _danix_launch_pi danix-vim "$repo_path" "$op_account" \
    ~/.config/dave_nix/danix-vim-prompt.md "$request"
}

# danix-pi — agentically add or tweak a Pi addon (skill, prompt template,
# or general piSettings in modules/home-manager/pi.nix). Refuses to start
# on a dirty tree.
danix-pi() {
  local op_account repo_path request
  op_account="$(cat ~/.config/dave_nix/op-account 2>/dev/null)"
  repo_path="$(cat ~/.config/dave_nix/repo-path 2>/dev/null)"
  if [ -z "$repo_path" ]; then
    echo "danix-pi: ~/.config/dave_nix/repo-path is missing — run danix-switch once first." >&2
    return 1
  fi
  _danix_require_clean_tree danix-pi "$repo_path" || return 1
  if [ $# -gt 0 ]; then
    request="$1"
  else
    print -P "%F{cyan}danix-pi%f — what Pi addon would you like to add or change?"
    print -P "%F{cyan}        %f (skills, prompt templates, or general Pi settings; empty = drop into Pi TUI)"
    printf "> "
    IFS= read -r request || request=""
  fi
  _danix_launch_pi danix-pi "$repo_path" "$op_account" \
    ~/.config/dave_nix/danix-pi-prompt.md "$request"
}

# ---------------------------------------------------------------------------
# `danix` launcher
#
# `danix`           → fzf menu of helpers.
# `danix <sub>`     → runs `danix-<sub>` directly (composes with history).
#
# Single source of truth: add a new helper by adding one line here.
# ---------------------------------------------------------------------------
typeset -gA _DANIX_COMMANDS=(
  add     "Agentically make a change to this flake"
  ask     "Ask Pi questions about this nix setup (read-only)"
  pi      "Agentically add/tweak a Pi addon (skill, prompt template, or settings)"
  switch  "Rebuild & activate the system (sudo)"
  up      "nix flake update + switch"
  update  "Agentically update manually-wrapped packages"
  vim     "Agentically make a change to the neovim (davim) config"
)

danix() {
  if (( $# > 0 )); then
    local sub="$1"; shift
    if [[ -z "${_DANIX_COMMANDS[$sub]+x}" ]]; then
      echo "danix: unknown subcommand '$sub'" >&2
      echo "available: ${(ko)_DANIX_COMMANDS}" >&2
      return 2
    fi
    "danix-$sub" "$@"
    return
  fi

  local choice
  choice=$(
    for k in ${(ko)_DANIX_COMMANDS}; do
      printf '%s\t%s\n' "$k" "${_DANIX_COMMANDS[$k]}"
    done | fzf --with-nth=1,2 --delimiter=$'\t' \
               --prompt='danix> ' --height=40% --reverse \
               --header='Pick a danix-* helper'
  ) || return 130
  local sub="${choice%%$'\t'*}"
  [[ -n $sub ]] && "danix-$sub"
}

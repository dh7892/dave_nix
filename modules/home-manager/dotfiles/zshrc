
# Yazi shell wrapper -- cd to yazi's cwd on exit
function yy() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

# Auto-attach to Zellij (skip in VS Code, cmux, or if already inside a multiplexer)
if [[ -z "$TMUX" && -z "$ZELLIJ" && -z "$VSCODE_PID" && -z "$CMUX_WORKSPACE_ID" ]]; then
  zellij attach default || zellij -s default
fi

# Source local settings if present (personal aliases, env vars, etc.).
# This file is intentionally not Nix-managed: it's a scratch space for
# quick per-machine tweaks that don't warrant a rebuild. Anything
# structured / long-lived should go in ~/.config/dave_nix/private.nix.
if [ -e "${HOME}/local_shell_settings.sh" ]; then
  source "${HOME}/local_shell_settings.sh"
fi

# Worker for the `nixupdate-wrapped` alias (see modules/home-manager/default.nix).
# Kept as a function so it's available in non-interactive subshells too
# (e.g. when zellij spawns a pane via `zsh -ic ...`).
#
# We invoke `op run` explicitly here rather than relying on the `pi` alias,
# because zsh expands aliases lazily inside functions and that expansion is
# unreliable across interactive/non-interactive subshell boundaries. The
# `op-account` file is written by home-manager from `private.opAccount`.
_nixupdate_wrapped_run() {
  local op_account repo_path
  op_account="$(cat ~/.config/dave_nix/op-account 2>/dev/null)"
  repo_path="$(cat ~/.config/dave_nix/repo-path 2>/dev/null)"
  cd "$repo_path" && op run --account="$op_account" --env-file ~/.secrets.template --no-masking -- \
    pi --thinking medium "$(cat ~/.config/dave_nix/nix-update-wrapped-prompt.md)"
}
